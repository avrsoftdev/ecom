rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && 
             request.auth.uid == userId;
    }
    
    // Users collection - only admins can read/write all, users can read/write their own
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
        
    // Orders collection - users can read/write their own orders, admins can read all
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated(); // Authenticated users can create orders
      allow update: if isAdmin(); // Only admins can update order status
      allow delete: if isAdmin(); // Only admins can delete orders
    }
    
    // Cart items collection - users can read/write their own cart
    match /cart/{cartItemId} {
      allow read, write: if isOwner(resource.data.userId);
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }
    
    // Wishlist items collection - users can read/write their own wishlist
    match /wishlist/{wishlistItemId} {
      allow read, write: if isOwner(resource.data.userId);
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }
    
    // Reviews collection - authenticated users can read/write reviews
    match /reviews/{reviewId} {
      allow read: if true; // Public can read reviews
      allow write: if isAuthenticated(); // Authenticated users can write reviews
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // Admin settings - only admins can access
    match /admin/{documentId} {
      allow list: if isAdmin(); // Admins can list all settings
      allow read: if isAdmin(); // Admins can read all settings
      allow write: if isAdmin(); // Admins can write all settings
      allow create: if isAdmin(); // Admins can create new settings
      allow update: if isAdmin(); // Admins can update existing settings
      allow delete: if isAdmin(); // Admins can delete settings
    }
    
    // Store settings - only admins can access
    match /settings/{documentId} {
      allow read: if isAdmin(); // Admins can read settings
      allow write: if isAdmin(); // Admins can write settings
      allow create: if isAdmin(); // Admins can create settings
      allow update: if isAdmin(); // Admins can update settings
      allow delete: if isAdmin(); // Admins can delete settings
    }
    
    // Collection list permissions for admin
    match /categories/{categoryId} {
      allow list: if isAdmin(); // Admins can list all categories
      allow read: if isAdmin() || (resource.data.isActive == true); // Admins can read all, public only active
      allow write: if isAdmin(); // Only admins can write categories
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Collection list permissions for admin
    match /banners/{bannerId} {
      allow list: if isAdmin(); // Admins can list all banners
      allow read: if isAdmin() || (resource.data.isActive == true); // Admins can read all, public only active
      allow write: if isAdmin(); // Only admins can write banners
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Collection list permissions for admin
    match /products/{productId} {
      allow list: if isAdmin(); // Admins can list all products
      allow read: if isAdmin() || (resource.data.isActive == true); // Admins can read all, public only active
      allow write: if isAdmin(); // Only admins can write products
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Deny all other reads/writes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}