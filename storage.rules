rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.role == 'admin';
    }
    
    // Product images - only admins can upload
    match /products/{productId}/{allPaths=**} {
      allow read: if true; // Public can read product images
      allow write: if isAdmin(); // Only admins can upload product images
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Banner images - only admins can upload
    match /banners/{bannerId}/{allPaths=**} {
      allow read: if true; // Public can read banner images
      allow write: if isAdmin(); // Only admins can upload banner images
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Category images - only admins can upload
    match /categories/{categoryId}/{allPaths=**} {
      allow read: if true; // Public can read category images
      allow write: if isAdmin(); // Only admins can upload category images
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // User profile images - authenticated users can upload their own
    match /users/{userId}/{allPaths=**} {
      allow read: if true; // Public can read profile images
      allow write: if isAuthenticated() && request.auth.uid == userId; // Users can upload their own images
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
